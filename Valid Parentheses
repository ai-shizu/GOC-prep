class Solution:
    def isValid(self, s: str) -> bool:
        count = []
        ans = 0 
        for x in s:
            if x =='(' or x == '{' or x == '[':
                count.append(x)
                ans += 1
            if x == ')':
                if not count:
                    return False
                y = count.pop()
                if y == '(':
                    ans -= 1
                if y != '(':
                    return False
            if x == '}':
                if not count:
                    return False
                y = count.pop()
                if y == '{':
                    ans -= 1
                if y != '{':
                    return False
            if x == ']':
                if not count:
                    return False
                y = count.pop()
                if y == '[':
                    ans -= 1
                if y != '[':
                    return False
        if ans == 0:
            return True
        else:
            return False


        

        