class Solution:
    def maxArea(self, heights: List[int]) -> int:
        n = len(heights)
        left = 0
        right = n - 1
        volume = 0
        ans  = 0

        while left < right:
            h = min(heights[left], heights[right])
            volume = h * (right-left)
            ans = max(ans, volume)
            if heights[left] < heights[right]:
                left += 1
            else:
                right -= 1
        return ans