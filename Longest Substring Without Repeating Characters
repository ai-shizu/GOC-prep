class Solution:
    def lengthOfLongestSubstring(self, s: str) -> int:
        left = 0
        right = 0
        ans = 0
        alph = set()
        for right in range(len(s)):
            while s[right] in alph:
                alph.remove(s[left])
                left += 1
            alph.add(s[right])
            
            ans = max(right - left + 1, ans)
        return ans