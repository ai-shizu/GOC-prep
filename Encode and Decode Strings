class Solution:
    def productExceptSelf(self, nums: List[int]) -> List[int]:
        ans = []
        for i in range(len(nums)): 
            a = 1
            b = 1
            for l in range(0,i):
                a = a * nums[l]
            for s in range(i+1,len(nums)):
                b = b * nums[s]
            ans.append(a*b)
        return ans