class Solution:
    def minWindow(self, s: str, t: str) -> str:
        from collections import defaultdict
        target_count = defaultdict(int)
        window_count = defaultdict(int)
        left = 0
        right = 0
        n = len(s)
        have = 0
        need = 0
        ans_len = float("inf")
        ans_left = -1
        ans_right = -1
        for char in t:
            target_count[char] += 1
        for x in target_count.keys():
            need += 1
        while right < n:
            char = s[right]
            window_count[char] += 1
            if char in t and window_count[char] == target_count[char]:
                have += 1
            while need == have:
                if right - left + 1 < ans_len:
                    ans_len = right - left + 1
                    ans_left = left
                    ans_right = right
                left_char = s[left]
                window_count[left_char] -= 1
                if left_char in target_count and window_count[left_char] < target_count[left_char]:
                    have -= 1
                    
                left += 1

            right += 1
        if ans_len == float('inf'):
            return ""
        return s[ans_left:ans_right+1]